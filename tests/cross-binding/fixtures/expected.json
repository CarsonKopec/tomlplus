{
  "app.name": "kitchen-sink",
  "builtins": {
    "no": false,
    "nothing": null,
    "yes": true
  },
  "debug": false,
  "empty": null,
  "features": {
    "colors": {
      "primary": "#FF0000",
      "secondary": "#00FF00"
    }
  },
  "numerics": {
    "bin": 22,
    "hex_lower": 255,
    "hex_upper": 255,
    "neg": -16,
