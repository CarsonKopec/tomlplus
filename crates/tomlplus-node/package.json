{
  "name": "tomlplus",
  "version": "2.0.0-rc.0.1",
  "description": "TOML+ — extended configuration format (Rust-backed Node.js native module)",
  "main": "index.js",
  "types": "index.d.ts",
  "repository": "https://github.com/CarsonKopec/tomlplus",
  "license": "MIT",
  "keywords": ["toml", "config", "configuration", "parser", "annotations", "tomlplus"],
  "napi": {
    "name": "tomlplus",
    "triples": {
      "defaults": true,
      "additional": [
        "x86_64-unknown-linux-musl",
        "aarch64-unknown-linux-gnu",
        "aarch64-apple-darwin",
        "aarch64-pc-windows-msvc"
      ]
    }
  },
  "files": ["index.js", "index.d.ts"],
  "scripts": {
    "build":        "napi build --platform --release",
    "build:debug":  "napi build --platform",
    "test":         "node --test test.mjs",
    "prepublishOnly": "napi prepublish --skip-gh-release"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18.4"
  },
  "engines": {
    "node": ">= 14"
  }
}
